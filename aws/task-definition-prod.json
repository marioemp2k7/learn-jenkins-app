{
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "family": "LearnJenkinsApp-TaskDefinition-Prod1",
    "containerDefinitions": [
        {
            "name": "learnjenkinsapp",
            "image": "238991998564.dkr.ecr.us-east-1.amazonaws.com/learnjenkinsapp:1.0.32",
            "portMappings": [
                {
                    "name": "nginx-80-tip",
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true
        }
    ],
    "volumes": [],
    "networkMode": "awsvpc",
    "memory": "2048",
    "cpu": "1024",
    "executionRoleArn": "arn:aws:iam::238991998564:role/ecsTaskExecutionRole"
}